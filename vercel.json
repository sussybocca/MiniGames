{
  "version": 2,
  "public": "wwwroot",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.gb",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/games/(.*)\\.gb",
      "dest": "/games/$1.gb"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
