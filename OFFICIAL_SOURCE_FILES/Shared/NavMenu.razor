@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable
@using Toolbelt.Blazor.Gamepad
@using System.Timers

<!-- Mode Toggle Buttons -->
<div style="position: fixed; bottom: 20px; right: 20px; z-index: 1000; display: flex; flex-direction: column; gap: 10px;">
    <button @onclick="ToggleHandMode" style="padding: 12px 20px; background: @(_handMode ? "#4CAF50" : "#f44336"); color: white; border: none; border-radius: 50px; font-size: 16px; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.3); transition: all 0.3s;">
        <span style="margin-right: 8px;">🖐️</span> Hand: @(_handMode ? "ON" : "OFF")
    </button>
    <button @onclick="ToggleBluetoothMode" style="padding: 12px 20px; background: @(_bluetoothMode ? "#4CAF50" : "#f44336"); color: white; border: none; border-radius: 50px; font-size: 16px; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.3); transition: all 0.3s;">
        <span style="margin-right: 8px;">🎧</span> Bluetooth: @(_bluetoothMode ? "ON" : "OFF")
    </button>
    <button @onclick="ToggleVoiceMode" style="padding: 12px 20px; background: @(_voiceMode ? "#4CAF50" : "#f44336"); color: white; border: none; border-radius: 50px; font-size: 16px; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.3); transition: all 0.3s;">
        <span style="margin-right: 8px;">🗣️</span> Voice: @(_voiceMode ? "ON" : "OFF")
    </button>
    <button @onclick="ToggleEyeMode" style="padding: 12px 20px; background: @(_eyeMode ? "#4CAF50" : "#f44336"); color: white; border: none; border-radius: 50px; font-size: 16px; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.3); transition: all 0.3s;">
        <span style="margin-right: 8px;">👁️</span> Eye: @(_eyeMode ? "ON" : "OFF")
    </button>
    <button @onclick="ToggleGamepadMode" style="padding: 12px 20px; background: @(_gamepadMode ? "#4CAF50" : "#f44336"); color: white; border: none; border-radius: 50px; font-size: 16px; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.3); transition: all 0.3s;">
        <span style="margin-right: 8px;">🎮</span> Gamepad: @(_gamepadMode ? "ON" : "OFF")
    </button>
</div>

<!-- Hidden canvas for hand tracking overlay (only visible when hand mode is active) -->
<canvas id="handCanvas" style="display: @(_handMode ? "block" : "none"); position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 999; background: transparent;"></canvas>

<div class="nav-menu">
    <NavLink class="nav-link" id="nav-home" href="" Match="NavLinkMatch.All">
        <span class="nav-icon">🏠</span> Home
    </NavLink>
    <NavLink class="nav-link" id="nav-about" href="about">
        <span class="nav-icon">ℹ️</span> About
    </NavLink>

    @{
        string GetIcon(bool isOpen) => isOpen ? "-" : "+";
    }

    <!-- DS Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("ds")'>
            <span>🎮 Nintendo DS</span>
            <span class="toggle-icon">@GetIcon(_dsOpen)</span>
        </div>
        @if (_dsOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-ds" href="/game/dude?device=ds">Play DS</NavLink>
            </div>
        }
    </div>

    <!-- Mobile Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("mobile")'>
            <span>📱 Mobile</span>
            <span class="toggle-icon">@GetIcon(_mobileOpen)</span>
        </div>
        @if (_mobileOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-mobile" href="/game/dude?device=mobile">Play Mobile</NavLink>
            </div>
        }
    </div>

    <!-- Computer Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("computer")'>
            <span>💻 Computer</span>
            <span class="toggle-icon">@GetIcon(_computerOpen)</span>
        </div>
        @if (_computerOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-computer" href="/game/dude?device=computer">Play Computer</NavLink>
            </div>
        }
    </div>

    <!-- GameBoy 3 Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("gameboy3")'>
            <span>🎮 GameBoy 3</span>
            <span class="toggle-icon">@GetIcon(_gameboy3Open)</span>
        </div>
        @if (_gameboy3Open)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-gameboy3" href="/gameboy3/play">Play GameBoy 3</NavLink>
            </div>
        }
    </div>

    <!-- Universal Modder Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("universalModder")'>
            <span>🛠️ Universal Modder</span>
            <span class="toggle-icon">@GetIcon(_universalModderOpen)</span>
        </div>
        @if (_universalModderOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-universal-modder" href="/emulator/universal-modder">Launch Modder</NavLink>
            </div>
        }
    </div>

    <!-- Three.js Examples Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("three")'>
            <span>🎨 Three.js Examples</span>
            <span class="toggle-icon">@GetIcon(_threeOpen)</span>
        </div>
        @if (_threeOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-three" href="/three">View Gallery</NavLink>
            </div>
        }
    </div>

    <!-- Hand Navigation Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("handNav")'>
            <span>🖐️ Hand Navigation</span>
            <span class="toggle-icon">@GetIcon(_handNavOpen)</span>
        </div>
        @if (_handNavOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-hand-nav" href="/hand-nav">Gesture Art</NavLink>
                <NavLink class="nav-link sub" id="nav-hand-control" href="/hand-control">Control Menu</NavLink>
            </div>
        }
    </div>

    <!-- UNIVERSAL FRONTEND EMULATOR (UFE) SECTION – NEW -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("ufe")'>
            <span>🎮 UFE (Flash/GBA/PS1)</span>
            <span class="toggle-icon">@GetIcon(_ufeOpen)</span>
        </div>
        @if (_ufeOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-ufe-flash" href="/ufe/play?system=flash">Flash Games</NavLink>
                <NavLink class="nav-link sub" id="nav-ufe-gba" href="/ufe/play?system=gba">GBA Games</NavLink>
                <NavLink class="nav-link sub" id="nav-ufe-ps1" href="/ufe/play?system=ps1">PS1 Games</NavLink>
            </div>
        }
    </div>

    <!-- PC Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("pc")'>
            <span>💻 PC (Custom)</span>
            <span class="toggle-icon">@GetIcon(_pcOpen)</span>
        </div>
        @if (_pcOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-pc" href="/pc/play">Play PC</NavLink>
            </div>
        }
    </div>

    <!-- Nintendo DS2 Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("nds2")'>
            <span>🎮 Nintendo DS2</span>
            <span class="toggle-icon">@GetIcon(_nds2Open)</span>
        </div>
        @if (_nds2Open)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-nds2" href="/nds2/play">Play DS2</NavLink>
            </div>
        }
    </div>

    <!-- Nintendo DS3 Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("ds3")'>
            <span>🎮 Nintendo DS3</span>
            <span class="toggle-icon">@GetIcon(_ds3Open)</span>
        </div>
        @if (_ds3Open)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-ds3" href="/ds3/play">Play DS3</NavLink>
            </div>
        }
    </div>

    <!-- JSON Service Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("jsonService")'>
            <span>📄 JSON Game Generator</span>
            <span class="toggle-icon">@GetIcon(_jsonServiceOpen)</span>
        </div>
        @if (_jsonServiceOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-json-service" href="/json-service">Create Game</NavLink>
            </div>
        }
    </div>

    <!-- Trippy Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("trippy")'>
            <span>🌀 Trippy C# Playground</span>
            <span class="toggle-icon">@GetIcon(_trippyOpen)</span>
        </div>
        @if (_trippyOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-trippy" href="/trippy/play">Play</NavLink>
            </div>
        }
    </div>

    <!-- TV Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("tv")'>
            <span>📺 Big Screen TV</span>
            <span class="toggle-icon">@GetIcon(_tvOpen)</span>
        </div>
        @if (_tvOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-tv" href="/tv/play">Watch TV</NavLink>
            </div>
        }
    </div>

    <!-- Chaos Test Section -->
    <div class="nav-section">
        <div class="nav-section-header" @onclick='() => ToggleSection("chaosTest")'>
            <span>🌀 Chaos Test</span>
            <span class="toggle-icon">@GetIcon(_chaosTestOpen)</span>
        </div>
        @if (_chaosTestOpen)
        {
            <div class="nav-submenu">
                <NavLink class="nav-link sub" id="nav-chaos-test" href="/chaos-test">Launch Test</NavLink>
            </div>
        }
    </div>
</div>

@code {
    private bool _dsOpen = false;
    private bool _mobileOpen = false;
    private bool _computerOpen = false;
    private bool _gbOpen = false;
    private bool _gameboy3Open = false;
    private bool _universalModderOpen = false;
    private bool _threeOpen = false;
    private bool _handNavOpen = false;
    private bool _ufeOpen = false; // New UFE section toggle
    private bool _atariOpen = false;
    private bool _pspOpen = false;
    private bool _pcOpen = false;
    private bool _nds2Open = false;
    private bool _ds3Open = false;
    private bool _jsonServiceOpen = false;
    private bool _trippyOpen = false;
    private bool _tvOpen = false;
    private bool _gb2Open = false;
    private bool _chaosTestOpen = false;

    private bool _handMode = false;
    private bool _bluetoothMode = false;
    private bool _voiceMode = false;
    private bool _eyeMode = false;
    private bool _gamepadMode = false;

    private DotNetObjectReference<NavMenu>? _dotNetRef;
    private Gamepad? _activeGamepad; // Track the active gamepad
    private readonly System.Timers.Timer _gamepadTimer = new System.Timers.Timer(100) { Enabled = false };
    private int _gamepadFocusIndex = -1; // -1 means no focus

    [Inject] private GamepadList GamepadList { get; set; } = default!;

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
        _gamepadTimer.Elapsed += GamepadTimer_Elapsed;
    }

    private async void GamepadTimer_Elapsed(object? sender, ElapsedEventArgs args)
    {
        var gamepads = await GamepadList.GetGamepadsAsync();
        var gamepad = gamepads.FirstOrDefault();
        if (gamepad != null && _activeGamepad != gamepad)
        {
            _activeGamepad = gamepad;
            await InvokeAsync(StateHasChanged);
        }

        if (_activeGamepad != null)
        {
            // Map D‑pad up/down to move focus through nav links
            if (_activeGamepad.Buttons[12].Pressed) // D‑pad up
            {
                MoveFocus(-1);
            }
            else if (_activeGamepad.Buttons[13].Pressed) // D‑pad down
            {
                MoveFocus(1);
            }

            // A button (index 0) clicks the focused link
            if (_activeGamepad.Buttons[0].Pressed && _gamepadFocusIndex != -1)
            {
                var allLinks = new[]
                {
                    "nav-home", "nav-about", "nav-ds", "nav-mobile", "nav-computer",
                    "nav-gameboy3", "nav-universal-modder", "nav-three", "nav-hand-nav",
                    "nav-hand-control", "nav-ufe-flash", "nav-ufe-gba", "nav-ufe-ps1",
                    "nav-pc", "nav-nds2", "nav-ds3", "nav-json-service", "nav-trippy",
                    "nav-tv", "nav-chaos-test"
                };
                if (_gamepadFocusIndex >= 0 && _gamepadFocusIndex < allLinks.Length)
                {
                    await JS.InvokeVoidAsync("eval", $"document.getElementById('{allLinks[_gamepadFocusIndex]}').click()");
                }
            }
        }
    }

    private void MoveFocus(int direction)
    {
        var allLinks = new[]
        {
            "nav-home", "nav-about", "nav-ds", "nav-mobile", "nav-computer",
            "nav-gameboy3", "nav-universal-modder", "nav-three", "nav-hand-nav",
            "nav-hand-control", "nav-ufe-flash", "nav-ufe-gba", "nav-ufe-ps1",
            "nav-pc", "nav-nds2", "nav-ds3", "nav-json-service", "nav-trippy",
            "nav-tv", "nav-chaos-test"
        };

        if (_gamepadFocusIndex == -1)
        {
            _gamepadFocusIndex = 0;
        }
        else
        {
            _gamepadFocusIndex = (_gamepadFocusIndex + direction + allLinks.Length) % allLinks.Length;
        }

        // Apply visual focus
        ClearAllHighlights();
        var js = $"document.getElementById('{allLinks[_gamepadFocusIndex]}')?.classList.add('gamepad-focus')";
        JS.InvokeVoidAsync("eval", js);
    }

    private async void ToggleHandMode()
    {
        _handMode = !_handMode;
        StateHasChanged();

        if (_handMode)
            await JS.InvokeVoidAsync("enableHandTracking", _dotNetRef);
        else
            await JS.InvokeVoidAsync("disableHandTracking");
    }

    private async void ToggleBluetoothMode()
    {
        _bluetoothMode = !_bluetoothMode;
        StateHasChanged();

        if (_bluetoothMode)
            await JS.InvokeVoidAsync("enableBluetoothMode", _dotNetRef);
        else
            await JS.InvokeVoidAsync("disableBluetoothMode");
    }

    private async void ToggleVoiceMode()
    {
        _voiceMode = !_voiceMode;
        StateHasChanged();

        if (_voiceMode)
            await JS.InvokeVoidAsync("enableVoiceControl", _dotNetRef);
        else
            await JS.InvokeVoidAsync("disableVoiceControl");
    }

    private async void ToggleEyeMode()
    {
        _eyeMode = !_eyeMode;
        StateHasChanged();

        if (_eyeMode)
            await JS.InvokeVoidAsync("enableEyeTracking", _dotNetRef);
        else
            await JS.InvokeVoidAsync("disableEyeTracking");
    }

    private async void ToggleGamepadMode()
    {
        _gamepadMode = !_gamepadMode;
        StateHasChanged();

        if (_gamepadMode)
        {
            _gamepadTimer.Enabled = true;
            _gamepadTimer.Start();
        }
        else
        {
            _gamepadTimer.Enabled = false;
            _gamepadTimer.Stop();
            ClearAllHighlights();
        }
    }

    [JSInvokable]
    public void OnVoiceCommand(string command)
    {
        var lower = command.ToLowerInvariant();
        if (lower.Contains("home")) Navigation.NavigateTo("/");
        else if (lower.Contains("about")) Navigation.NavigateTo("/about");
        else if (lower.Contains("gameboy")) Navigation.NavigateTo("/gameboy3/play");
        else if (lower.Contains("three")) Navigation.NavigateTo("/three");
        else if (lower.Contains("flash")) Navigation.NavigateTo("/ufe/play?system=flash");
        else if (lower.Contains("gba")) Navigation.NavigateTo("/ufe/play?system=gba");
        else if (lower.Contains("ps1")) Navigation.NavigateTo("/ufe/play?system=ps1");
    }

    [JSInvokable]
    public void OnEyeGaze(string elementId)
    {
        ClearAllHighlights();
        if (!string.IsNullOrEmpty(elementId))
        {
            var js = $"document.getElementById('{elementId}')?.classList.add('eye-focus')";
            JS.InvokeVoidAsync("eval", js);
        }
    }

    private void ClearAllHighlights()
    {
        var js = @"document.querySelectorAll('.voice-focus, .eye-focus, .gamepad-focus, .hand-hover, .bt-focus').forEach(el => 
                    el.classList.remove('voice-focus', 'eye-focus', 'gamepad-focus', 'hand-hover', 'bt-focus'))";
        JS.InvokeVoidAsync("eval", js);
    }

    private void ToggleSection(string section)
    {
        switch (section)
        {
            case "ds": _dsOpen = !_dsOpen; break;
            case "mobile": _mobileOpen = !_mobileOpen; break;
            case "computer": _computerOpen = !_computerOpen; break;
            case "gameboy3": _gameboy3Open = !_gameboy3Open; break;
            case "universalModder": _universalModderOpen = !_universalModderOpen; break;
            case "three": _threeOpen = !_threeOpen; break;
            case "handNav": _handNavOpen = !_handNavOpen; break;
            case "ufe": _ufeOpen = !_ufeOpen; break; // UFE toggle
            case "pc": _pcOpen = !_pcOpen; break;
            case "nds2": _nds2Open = !_nds2Open; break;
            case "ds3": _ds3Open = !_ds3Open; break;
            case "jsonService": _jsonServiceOpen = !_jsonServiceOpen; break;
            case "trippy": _trippyOpen = !_trippyOpen; break;
            case "tv": _tvOpen = !_tvOpen; break;
            case "chaosTest": _chaosTestOpen = !_chaosTestOpen; break;
        }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
        _gamepadTimer.Elapsed -= GamepadTimer_Elapsed;
        _gamepadTimer.Dispose();
        JS.InvokeVoidAsync("disableHandTracking");
        JS.InvokeVoidAsync("disableBluetoothMode");
        JS.InvokeVoidAsync("disableVoiceControl");
        JS.InvokeVoidAsync("disableEyeTracking");
    }
}

<style>
    .hand-hover {
        outline: 3px solid #4CAF50 !important;
        box-shadow: 0 0 20px #4CAF50 !important;
        background-color: rgba(76, 175, 80, 0.2) !important;
    }
    .bt-focus {
        outline: 3px solid #2196F3 !important;
        box-shadow: 0 0 20px #2196F3 !important;
        background-color: rgba(33, 150, 243, 0.2) !important;
    }
    .voice-focus {
        outline: 3px solid #FF9800 !important;
        box-shadow: 0 0 20px #FF9800 !important;
        background-color: rgba(255, 152, 0, 0.2) !important;
    }
    .eye-focus {
        outline: 3px solid #9C27B0 !important;
        box-shadow: 0 0 20px #9C27B0 !important;
        background-color: rgba(156, 39, 176, 0.2) !important;
    }
    .gamepad-focus {
        outline: 3px solid #FF5722 !important;
        box-shadow: 0 0 20px #FF5722 !important;
        background-color: rgba(255, 87, 34, 0.2) !important;
    }
</style>

<script>
    // ===== HAND TRACKING (unchanged from previous working version) =====
    let handTrackingActive = false;
    let canvas, ctx;
    let camera = null;
    let hands = null;
    let dotNetRef = null;
    let lastPinchTime = 0;
    const pinchCooldown = 500;

    function getDistance(p1, p2) {
        return Math.sqrt((p1.x - p2.x) ** 2 + (p1.y - p2.y) ** 2);
    }

    async function loadMediaPipe() {
        return new Promise((resolve, reject) => {
            if (window.Hands) {
                resolve();
                return;
            }
            const script1 = document.createElement('script');
            script1.src = 'https://cdn.jsdelivr.net/npm/@@mediapipe/hands/hands.js';
            script1.onload = () => {
                const script2 = document.createElement('script');
                script2.src = 'https://cdn.jsdelivr.net/npm/@@mediapipe/camera_utils/camera_utils.js';
                script2.onload = resolve;
                script2.onerror = reject;
                document.head.appendChild(script2);
            };
            script1.onerror = reject;
            document.head.appendChild(script1);
        });
    }

    window.enableHandTracking = async (dotNetObj) => {
        if (handTrackingActive) return;
        dotNetRef = dotNetObj;

        await loadMediaPipe();

        canvas = document.getElementById('handCanvas');
        ctx = canvas.getContext('2d');
        canvas.style.display = 'block';
        handTrackingActive = true;

        const videoElement = document.createElement('video');
        videoElement.style.display = 'none';
        document.body.appendChild(videoElement);

        hands = new Hands({ locateFile: (file) => `https://cdn.jsdelivr.net/npm/@@mediapipe/hands/${file}` });
        hands.setOptions({
            maxNumHands: 1,
            modelComplexity: 1,
            minDetectionConfidence: 0.5,
            minTrackingConfidence: 0.5
        });

        hands.onResults((results) => {
            if (!handTrackingActive) return;

            ctx.clearRect(0, 0, canvas.width, canvas.height);
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;

            if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
                const landmarks = results.multiHandLandmarks[0];
                const indexTip = landmarks[8];
                const x = indexTip.x * canvas.width;
                const y = indexTip.y * canvas.height;

                ctx.shadowColor = '#4CAF50';
                ctx.shadowBlur = 30;
                ctx.beginPath();
                ctx.arc(x, y, 25, 0, 2 * Math.PI);
                ctx.fillStyle = 'rgba(76, 175, 80, 0.3)';
                ctx.fill();
                ctx.shadowBlur = 15;
                ctx.strokeStyle = '#4CAF50';
                ctx.lineWidth = 4;
                ctx.stroke();
                ctx.shadowBlur = 0;

                ctx.beginPath();
                ctx.arc(x, y, 6, 0, 2 * Math.PI);
                ctx.fillStyle = '#4CAF50';
                ctx.fill();

                document.querySelectorAll('.nav-link.hand-hover').forEach(el => {
                    el.classList.remove('hand-hover');
                });

                const element = document.elementFromPoint(x, y);
                let hoveredNavLink = null;
                if (element) {
                    const navLink = element.closest('.nav-link');
                    if (navLink) {
                        navLink.classList.add('hand-hover');
                        hoveredNavLink = navLink;
                    }
                }

                const thumbTip = landmarks[4];
                const pinchDist = getDistance(
                    { x: thumbTip.x * canvas.width, y: thumbTip.y * canvas.height },
                    { x, y }
                );
                const now = Date.now();
                if (pinchDist < 30 && now - lastPinchTime > pinchCooldown) {
                    lastPinchTime = now;
                    if (hoveredNavLink) {
                        hoveredNavLink.click();
                    }
                }
            } else {
                document.querySelectorAll('.nav-link.hand-hover').forEach(el => {
                    el.classList.remove('hand-hover');
                });
            }
        });

        camera = new Camera(videoElement, {
            onFrame: async () => {
                if (handTrackingActive) {
                    await hands.send({ image: videoElement });
                }
            },
            width: 640,
            height: 480
        });
        camera.start();
    };

    window.disableHandTracking = () => {
        handTrackingActive = false;
        if (canvas) canvas.style.display = 'none';
        if (camera) camera.stop();
        if (hands) hands.close();
        document.querySelectorAll('.nav-link.hand-hover').forEach(el => {
            el.classList.remove('hand-hover');
        });
    };

    // ===== BLUETOOTH HEADPHONE CONTROL =====
    let bluetoothActive = false;
    let btNavLinks = [];
    let btCurrentIndex = -1;

    function updateBtFocus() {
        document.querySelectorAll('.nav-link.bt-focus').forEach(el => el.classList.remove('bt-focus'));
        if (btCurrentIndex >= 0 && btCurrentIndex < btNavLinks.length) {
            btNavLinks[btCurrentIndex].classList.add('bt-focus');
            btNavLinks[btCurrentIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
    }

    function refreshNavLinks() {
        btNavLinks = Array.from(document.querySelectorAll('.nav-link'));
        if (btCurrentIndex >= btNavLinks.length) btCurrentIndex = -1;
        updateBtFocus();
    }

    window.enableBluetoothMode = (dotNetObj) => {
        if (bluetoothActive) return;
        bluetoothActive = true;
        dotNetRef = dotNetObj;
        refreshNavLinks();
        window.addEventListener('keydown', handleMediaKey);
    };

    window.disableBluetoothMode = () => {
        bluetoothActive = false;
        window.removeEventListener('keydown', handleMediaKey);
        document.querySelectorAll('.nav-link.bt-focus').forEach(el => el.classList.remove('bt-focus'));
    };

    window.handleMediaKey = (e) => {
        if (!bluetoothActive) return;
        e.preventDefault();
        btNavLinks = Array.from(document.querySelectorAll('.nav-link'));
        switch (e.code) {
            case 'VolumeUp':
                if (btNavLinks.length === 0) break;
                btCurrentIndex = (btCurrentIndex + 1) % btNavLinks.length;
                updateBtFocus();
                break;
            case 'VolumeDown':
                if (btNavLinks.length === 0) break;
                btCurrentIndex = (btCurrentIndex - 1 + btNavLinks.length) % btNavLinks.length;
                updateBtFocus();
                break;
            case 'MediaPlayPause':
                if (btCurrentIndex >= 0 && btCurrentIndex < btNavLinks.length) {
                    btNavLinks[btCurrentIndex].click();
                }
                break;
            case 'MediaTrackNext':
                window.scrollBy({ top: 100, behavior: 'smooth' });
                break;
            case 'MediaTrackPrevious':
                window.scrollBy({ top: -100, behavior: 'smooth' });
                break;
        }
    };

    // ===== VOICE CONTROL =====
    let voiceActive = false;
    let voiceRecognition = null;
    let voiceDotNetRef = null;

    window.enableVoiceControl = (dotNetObj) => {
        if (voiceActive) return;
        voiceDotNetRef = dotNetObj;
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (!SpeechRecognition) {
            alert("Voice control not supported in this browser.");
            return;
        }
        voiceRecognition = new SpeechRecognition();
        voiceRecognition.continuous = true;
        voiceRecognition.interimResults = false;
        voiceRecognition.lang = 'en-US';
        voiceRecognition.onresult = (event) => {
            const text = event.results[event.results.length - 1][0].transcript;
            voiceDotNetRef.invokeMethodAsync('OnVoiceCommand', text);
        };
        voiceRecognition.start();
        voiceActive = true;
    };

    window.disableVoiceControl = () => {
        if (voiceRecognition) {
            voiceRecognition.stop();
            voiceRecognition = null;
        }
        voiceActive = false;
        document.querySelectorAll('.nav-link.voice-focus').forEach(el => el.classList.remove('voice-focus'));
    };

    // ===== EYE TRACKING (WebGazer.js) =====
    let eyeActive = false;
    let eyeDotNetRef = null;
    let gazeInterval = null;

    window.enableEyeTracking = (dotNetObj) => {
        if (eyeActive) return;
        eyeDotNetRef = dotNetObj;
        if (typeof webgazer === 'undefined') {
            const script = document.createElement('script');
            script.src = 'https://webgazer.cs.brown.edu/webgazer.js';
            script.onload = () => {
                webgazer.setRegression('ridge').setTracker('clmtrackr').begin();
                webgazer.showVideo(false).showPredictionPoints(false);
                startGazeLoop();
            };
            document.head.appendChild(script);
        } else {
            startGazeLoop();
        }
        eyeActive = true;
    };

    function startGazeLoop() {
        if (gazeInterval) clearInterval(gazeInterval);
        gazeInterval = setInterval(() => {
            if (!eyeActive) return;
            webgazer.getCurrentPrediction().then(pred => {
                if (pred) {
                    const x = pred.x, y = pred.y;
                    const element = document.elementFromPoint(x, y);
                    if (element) {
                        const navLink = element.closest('.nav-link');
                        if (navLink && navLink.id) {
                            eyeDotNetRef.invokeMethodAsync('OnEyeGaze', navLink.id);
                        } else {
                            eyeDotNetRef.invokeMethodAsync('OnEyeGaze', '');
                        }
                    } else {
                        eyeDotNetRef.invokeMethodAsync('OnEyeGaze', '');
                    }
                }
            });
        }, 100);
    }

    window.disableEyeTracking = () => {
        eyeActive = false;
        if (gazeInterval) clearInterval(gazeInterval);
        if (typeof webgazer !== 'undefined') webgazer.end();
        document.querySelectorAll('.nav-link.eye-focus').forEach(el => el.classList.remove('eye-focus'));
    };

    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
        if (camera) camera.stop();
        if (hands) hands.close();
        if (bluetoothActive) {
            window.removeEventListener('keydown', handleMediaKey);
        }
        if (voiceActive && voiceRecognition) {
            voiceRecognition.stop();
        }
        if (eyeActive) {
            if (gazeInterval) clearInterval(gazeInterval);
            if (typeof webgazer !== 'undefined') webgazer.end();
        }
    });
</script>