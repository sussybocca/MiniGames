@namespace MiniGames.Emulators.Test
@attribute [Route("/chaos-test")]
@using System.Threading
@inject ChaosService Chaos
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="chaos-test-emulator @(Chaos?.GetRandomThemeClass() ?? "")" @onclick="HandleScreenTap">
    <div class="console-shell @(_showShake ? "chaos-shake" : "") @(_showSpin ? "chaos-spin" : "")">
        <!-- Screen -->
        <div class="screen-bezel @(_showWave ? "chaos-wave" : "") @(_showVHS ? "chaos-vhs" : "") @(_showLag ? "chaos-lag" : "")">
            <div class="screen-glare"></div>
            <div class="screen-content @(_showCorrupt ? "chaos-corrupt" : "")">
                @if (_showGlitch)
                {
                    <div class="glitch-overlay"></div>
                }
                @if (_showStatic)
                {
                    <div class="static-overlay"></div>
                }
                @if (_showColorShift)
                {
                    <div class="color-shift"></div>
                }
                @if (Chaos?.ShouldSimulateError() == true || _forceError)
                {
                    <div class="simulated-error">
                        <strong>⚠️ @_errorTitle</strong>
                        <p>@_errorMessage</p>
                        <button @onclick="ReloadGame">Reset</button>
                    </div>
                }
                else
                {
                    <iframe src="@GameUrl" @ref="gameFrame" class="game-frame"></iframe>
                }
            </div>
            <div class="scanlines"></div>
            <div class="pixel-grid"></div>
        </div>

        <!-- Controls -->
        <div class="controls-panel @(_showShake ? "chaos-shake" : "")">
            <div class="dpad-section">
                <div class="dpad">
                    <button class="dpad-up" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("ArrowUp")' @onmouseup='() => SendKey("ArrowUp", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>↑</button>
                    <button class="dpad-down" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("ArrowDown")' @onmouseup='() => SendKey("ArrowDown", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>↓</button>
                    <button class="dpad-left" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("ArrowLeft")' @onmouseup='() => SendKey("ArrowLeft", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>←</button>
                    <button class="dpad-right" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("ArrowRight")' @onmouseup='() => SendKey("ArrowRight", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>→</button>
                </div>
            </div>
            <div class="action-section">
                <button class="btn-a" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("a")' @onmouseup='() => SendKey("a", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>A</button>
                <button class="btn-b" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("b")' @onmouseup='() => SendKey("b", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>B</button>
                <button class="btn-x" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("x")' @onmouseup='() => SendKey("x", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>X</button>
                <button class="btn-y" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("y")' @onmouseup='() => SendKey("y", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>Y</button>
            </div>
            <div class="shoulder-section">
                <button class="btn-l" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("l")' @onmouseup='() => SendKey("l", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>L</button>
                <button class="btn-r" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("r")' @onmouseup='() => SendKey("r", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>R</button>
            </div>
            <div class="system-section">
                <button class="btn-start" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("Start")' @onmouseup='() => SendKey("Start", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>Start</button>
                <button class="btn-select" @onmousedown:preventDefault="true" @onmousedown='() => SendKey("Select")' @onmouseup='() => SendKey("Select", "up")' @onclick='() => Chaos?.LogRandomConsoleError(JS)'>Select</button>
            </div>
        </div>

        <!-- Status -->
        <div class="status-panel">
            <div class="power-indicator @(_powerOn ? "on" : "off")"></div>
            <div class="fps-indicator">FPS: @(_showLag ? _lagFps : _fps)</div>
            <div class="battery-indicator">🔋 @_battery%</div>
            <div class="wifi-indicator">@_wifiSymbol</div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string GameUrl { get; set; } = "";
    private ElementReference gameFrame;

    // Chaos / Glitch states
    private bool _showGlitch = false;
    private bool _showStatic = false;
    private bool _showColorShift = false;
    private bool _showShake = false;
    private bool _showSpin = false;
    private bool _showPixelate = false;
    private bool _showWave = false;
    private bool _showVHS = false;
    private bool _showCorrupt = false;
    private bool _showLag = false;
    private bool _forceError = false;
    private string _errorTitle = "SYSTEM ERROR";
    private string _errorMessage = "Exception: 0xDEADBEEF";
    private bool _powerOn = true;
    private int _battery = 87;
    private string _wifiSymbol = "📶";
    private int _lagFps = 15; // Low FPS during lag effect

    private readonly string[] _systemErrors = new[]
    {
        "FATAL: Exception 0xC0000005 (ACCESS_VIOLATION) at 0x7C34B8F2",
        "Firmware corrupted – performing recovery...",
        "KERNEL_DATA_INPAGE_ERROR (0x0000007A)",
        "ACPI_BIOS_ERROR (0x000000A5)",
        "HARDWARE FAILURE: contact support"
    };

    private int _fps = 60;
    private DateTime _lastFrame = DateTime.Now;
    private System.Threading.Timer? _fpsTimer;
    private System.Threading.Timer? _chaosTimer;

    protected override void OnInitialized()
    {
        _fpsTimer = new System.Threading.Timer(_ =>
        {
            var now = DateTime.Now;
            var diff = (now - _lastFrame).TotalSeconds;
            _lastFrame = now;
            if (diff > 0)
            {
                _fps = (int)Math.Round(1.0 / diff);
            }
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));

        _chaosTimer = new System.Threading.Timer(async _ =>
        {
            if (Chaos?.IsChaosModeEnabled == true)
            {
                if (new Random().Next(3) == 0)
                {
                    Chaos.LogRandomConsoleError(JS);
                }

                var (effect, duration) = Chaos.GetRandomGlitchEffect();
                if (!string.IsNullOrEmpty(effect))
                {
                    await InvokeAsync(() => ApplyGlitchEffect(effect, duration));
                }

                if (new Random().Next(10) == 0)
                {
                    _battery = Math.Max(0, _battery - 1);
                    _wifiSymbol = new[] { "📶", "📶", "📶", "📡", "✗" }[new Random().Next(5)];
                    StateHasChanged();
                }
            }
        }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(4));
    }

    private void ApplyGlitchEffect(string effect, int durationMs)
    {
        var rand = new Random();
        switch (effect)
        {
            case "glitch":
                _showGlitch = true;
                _ = Task.Delay(durationMs).ContinueWith(_ => InvokeAsync(() => _showGlitch = false));
                break;
            case "static":
                _showStatic = true;
                _ = Task.Delay(durationMs).ContinueWith(_ => InvokeAsync(() => _showStatic = false));
                break;
            case "colorShift":
                _showColorShift = true;
                _ = Task.Delay(durationMs).ContinueWith(_ => InvokeAsync(() => _showColorShift = false));
                break;
            case "flicker":
                _powerOn = false;
                _ = Task.Delay(durationMs).ContinueWith(_ => InvokeAsync(() => _powerOn = true));
                break;
            case "pixelate":
                _showPixelate = true;
                _ = Task.Delay(durationMs).ContinueWith(_ => InvokeAsync(() => _showPixelate = false));
                break;
            case "wave":
                _showWave = true;
                _ = Task.Delay(durationMs).ContinueWith(_ => InvokeAsync(() => _showWave = false));
                break;
            case "vhs":
                _showVHS = true;
                _ = Task.Delay(durationMs).ContinueWith(_ => InvokeAsync(() => _showVHS = false));
                break;
            case "corrupt":
                _showCorrupt = true;
                _forceError = true;
                _errorMessage = _systemErrors[rand.Next(_systemErrors.Length)];
                _errorTitle = "SYSTEM CORRUPTION";
                _ = Task.Delay(durationMs).ContinueWith(_ => InvokeAsync(() => { _showCorrupt = false; _forceError = false; }));
                break;
            case "lag":
                _showLag = true;
                _ = Task.Delay(durationMs).ContinueWith(_ => InvokeAsync(() => _showLag = false));
                break;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Ensure the global helper exists (defined in chaos-test.js)
            await JS.InvokeVoidAsync("eval", @"
                if (!window.chaosTestEmulator) {
                    window.chaosTestEmulator = {
                        sendKey: (iframe, key, action) => {
                            const iframeWindow = iframe.contentWindow;
                            if (!iframeWindow) return;
                            iframe.focus();
                            const keyMap = {
                                'ArrowUp': { key: 'ArrowUp', code: 'ArrowUp', keyCode: 38 },
                                'ArrowDown': { key: 'ArrowDown', code: 'ArrowDown', keyCode: 40 },
                                'ArrowLeft': { key: 'ArrowLeft', code: 'ArrowLeft', keyCode: 37 },
                                'ArrowRight': { key: 'ArrowRight', code: 'ArrowRight', keyCode: 39 },
                                'a': { key: 'a', code: 'KeyA', keyCode: 65 },
                                'b': { key: 'b', code: 'KeyB', keyCode: 66 },
                                'x': { key: 'x', code: 'KeyX', keyCode: 88 },
                                'y': { key: 'y', code: 'KeyY', keyCode: 89 },
                                'l': { key: 'l', code: 'KeyL', keyCode: 76 },
                                'r': { key: 'r', code: 'KeyR', keyCode: 82 },
                                'Start': { key: 'Enter', code: 'Enter', keyCode: 13 },
                                'Select': { key: ' ', code: 'Space', keyCode: 32 }
                            };
                            const props = keyMap[key] || { key: key, code: key, keyCode: key.charCodeAt(0) };
                            const eventType = action === 'down' ? 'keydown' : 'keyup';
                            const event = new KeyboardEvent(eventType, {
                                key: props.key,
                                code: props.code,
                                keyCode: props.keyCode,
                                which: props.keyCode,
                                bubbles: true,
                                cancelable: true,
                                composed: true
                            });
                            iframeWindow.dispatchEvent(event);
                            iframeWindow.document.activeElement?.dispatchEvent(event);
                        }
                    };
                }
            ");
        }
    }

    private async Task SendKey(string key, string action = "down")
    {
        await JS.InvokeVoidAsync("chaosTestEmulator.sendKey", gameFrame, key, action);
    }

    private void HandleScreenTap()
    {
        _ = JS.InvokeVoidAsync("chaosTestEmulator.focus", gameFrame);
    }

    private void ReloadGame()
    {
        GameUrl = GameUrl + "?reload=" + Guid.NewGuid();
    }

    public void Dispose()
    {
        _fpsTimer?.Dispose();
        _chaosTimer?.Dispose();
    }
}