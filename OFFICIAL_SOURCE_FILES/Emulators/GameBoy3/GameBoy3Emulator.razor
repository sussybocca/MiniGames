@page "/gameboy3/play"
@page "/gameboy3/play/{gamePath?}"
@namespace MiniGames.Emulators.GameBoy3
@using coreboy
@using coreboy.memory.cart
@using coreboy.memory.cart.battery
@using coreboy.gpu
@using coreboy.sound
@using coreboy.serial
@using coreboy.controller
@using System.Threading.Tasks
@inject GameService GameService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject HttpClient Http

<div class="gb3-console">
    <div class="gb3-shell">
        <div class="screen-bezel">
            <canvas @ref="_canvas" class="game-canvas" width="160" height="144"></canvas>
            <div class="scanlines"></div>
        </div>
        <div class="controls">
            <div class="dpad">
                <button class="dpad-up" @onmousedown='() => SendKey("up", true)' @onmouseup='() => SendKey("up", false)'>↑</button>
                <button class="dpad-down" @onmousedown='() => SendKey("down", true)' @onmouseup='() => SendKey("down", false)'>↓</button>
                <button class="dpad-left" @onmousedown='() => SendKey("left", true)' @onmouseup='() => SendKey("left", false)'>←</button>
                <button class="dpad-right" @onmousedown='() => SendKey("right", true)' @onmouseup='() => SendKey("right", false)'>→</button>
            </div>
            <div class="action-buttons">
                <button class="btn-a" @onmousedown='() => SendKey("a", true)' @onmouseup='() => SendKey("a", false)'>A</button>
                <button class="btn-b" @onmousedown='() => SendKey("b", true)' @onmouseup='() => SendKey("b", false)'>B</button>
                <button class="btn-select" @onmousedown='() => SendKey("select", true)' @onmouseup='() => SendKey("select", false)'>Select</button>
                <button class="btn-start" @onmousedown='() => SendKey("start", true)' @onmouseup='() => SendKey("start", false)'>Start</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? gamePath { get; set; }

    private ElementReference _canvas;
    private Gameboy? _gameboy;
    private CancellationTokenSource? _cts;
    private bool _running;
    private string? _statusMessage;
    private BlazorDisplay _display = new();
    private BlazorController _controller = new();
    private TaskCompletionSource<byte[]>? _frameTcs;

    // ----- BlazorDisplay: Implements IDisplay for coreboy -----
    private class BlazorDisplay : IDisplay
    {
        private readonly int[] _frameBuffer = new int[160 * 144];
        private readonly object _lock = new();
        private int _pixelIndex = 0;
        private bool _enabled = true;
        private byte[]? _lastFrameData;

        // DMG palette (4 shades of gray) – for correct color conversion
        private static readonly int[] DmgPalette = { 0xFFFFFFFF, 0xFFAAAAAA, 0xFF555555, 0xFF000000 };

        public bool Enabled
        {
            get => _enabled;
            set => _enabled = value;
        }

        public event FrameProducedEventHandler? OnFrameProduced;

        public void Run(CancellationToken token) { } // Not used in this context

        public void PutDmgPixel(int colorIndex)
        {
            lock (_lock)
            {
                if (_pixelIndex < _frameBuffer.Length)
                    _frameBuffer[_pixelIndex++] = DmgPalette[colorIndex & 0x3]; // Convert index to ARGB
            }
        }

        public void PutColorPixel(int gbcRgb)
        {
            // GBC 15-bit RGB (0-31 each) -> ARGB
            int r = (gbcRgb >> 0) & 0x1F;
            int g = (gbcRgb >> 5) & 0x1F;
            int b = (gbcRgb >> 10) & 0x1F;
            int argb = 0xFF000000 | (r << 19) | (g << 11) | (b << 3); // Approximate conversion
            lock (_lock)
            {
                if (_pixelIndex < _frameBuffer.Length)
                    _frameBuffer[_pixelIndex++] = argb;
            }
        }

        public void RequestRefresh()
        {
            lock (_lock)
            {
                byte[] rgba = new byte[_frameBuffer.Length * 4];
                for (int i = 0; i < _frameBuffer.Length; i++)
                {
                    int argb = _frameBuffer[i];
                    rgba[i * 4] = (byte)((argb >> 16) & 0xFF); // R
                    rgba[i * 4 + 1] = (byte)((argb >> 8) & 0xFF); // G
                    rgba[i * 4 + 2] = (byte)(argb & 0xFF); // B
                    rgba[i * 4 + 3] = (byte)((argb >> 24) & 0xFF); // A
                }
                _lastFrameData = rgba;
                _pixelIndex = 0;
            }
            OnFrameProduced?.Invoke(this, _lastFrameData ?? Array.Empty<byte>());
        }

        public void WaitForRefresh() { } // Non‑blocking; emulator runs as fast as possible

        public byte[]? GetLastFrameData()
        {
            lock (_lock) { return _lastFrameData; }
        }
    }

    // ----- BlazorController: Implements IController for coreboy -----
    private class BlazorController : IController
    {
        private IButtonListener? _listener;

        public void SetButtonListener(IButtonListener listener)
        {
            _listener = listener;
        }

        public void PressButton(Button button)
        {
            _listener?.OnButtonPress(button);
        }

        public void ReleaseButton(Button button)
        {
            _listener?.OnButtonRelease(button);
        }
    }

    // ----- Lifecycle -----
    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(gamePath))
        {
            _statusMessage = "No game selected.";
            return;
        }

        var games = await GameService.GetGamesAsync();
        var game = games.FirstOrDefault(g => g.Folder.Equals(gamePath, StringComparison.OrdinalIgnoreCase));
        if (game == null)
        {
            _statusMessage = "Game not found.";
            return;
        }

        try
        {
            await StartEmulatorAsync(game.GamePath);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Failed to load ROM: {ex.Message}";
        }
    }

    private async Task StartEmulatorAsync(string romPath)
    {
        // For Blazor WebAssembly, you need to fetch the ROM as bytes.
        // Adjust the URL to where your ROMs are stored (e.g., "roms/tetris.gb").
        var romBytes = await Http.GetByteArrayAsync(romPath);

        // Create cartridge from bytes (requires a Cartridge constructor that accepts byte[]).
        // If your coreboy-net8 version doesn't have it, you'll need to add it (see notes).
        var cartridge = new Cartridge(romBytes);

        var soundOutput = new NullSoundOutput();
        var serialEndpoint = new NullSerialEndpoint();

        _gameboy = new Gameboy(new GameboyOptions(), cartridge, _display, _controller, soundOutput, serialEndpoint);

        _cts = new CancellationTokenSource();
        _running = true;

        _display.OnFrameProduced += OnFrameProduced;

        // Run emulation on background thread
        _ = Task.Run(() =>
        {
            try
            {
                Console.WriteLine("Emulator thread started.");
                _gameboy.Run(_cts.Token);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Emulator thread error: {ex}");
            }
        }, _cts.Token);

        // Start rendering loop on UI thread
        _ = RenderLoop(_cts.Token);
    }

    private void OnFrameProduced(object sender, byte[] frameData)
    {
        _frameTcs?.TrySetResult(frameData);
    }

    private async Task RenderLoop(CancellationToken token)
    {
        while (!token.IsCancellationRequested && _running)
        {
            _frameTcs = new TaskCompletionSource<byte[]>();
            var frameData = await _frameTcs.Task;
            await RenderFrame(frameData);
        }
    }

    private async Task RenderFrame(byte[] rgba)
    {
        try
        {
            await JS.InvokeVoidAsync("gameboy3.render", _canvas, rgba);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Render error: {ex}");
        }
    }

    private void SendKey(string key, bool pressed)
    {
        Button? button = key.ToLower() switch
        {
            "up" => Button.Up,
            "down" => Button.Down,
            "left" => Button.Left,
            "right" => Button.Right,
            "a" => Button.A,
            "b" => Button.B,
            "select" => Button.Select,
            "start" => Button.Start,
            _ => null
        };

        if (button != null)
        {
            if (pressed)
                _controller.PressButton(button);
            else
                _controller.ReleaseButton(button);
        }
    }

    public void Dispose()
    {
        _running = false;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
